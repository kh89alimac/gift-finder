# Gift Finder Application Configuration
# Copy to .env and fill in your actual values before deployment

# ============================================================================
# Application Settings
# ============================================================================
APP_ENV=production
DEBUG=false
LOG_LEVEL=INFO

# Generate with: openssl rand -hex 32
SECRET_KEY=your-secret-key-here-min-32-chars-long-change-in-production

# Generate with: openssl rand -hex 32
JWT_SECRET=your-jwt-secret-here-min-32-chars-long-change-in-production

# CORS origins (comma-separated for multiple)
CORS_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# ============================================================================
# Database Configuration
# ============================================================================
DB_USER=gift
DB_PASSWORD=your-secure-db-password-here
DB_NAME=giftfinder
DB_PORT=5432

# Full connection string (used by app if DATABASE_URL is not set)
# Format: postgresql+asyncpg://user:password@host:port/dbname
# DATABASE_URL=postgresql+asyncpg://gift:password@postgres:5432/giftfinder

# ============================================================================
# Redis Configuration
# ============================================================================
REDIS_PORT=6379
REDIS_MAX_MEMORY=256mb

# Full connection string (used by app if REDIS_URL is not set)
# REDIS_URL=redis://redis:6379/0

# ============================================================================
# AWS S3 Configuration (for image storage)
# ============================================================================
AWS_ACCESS_KEY_ID=your-aws-access-key-id
AWS_SECRET_ACCESS_KEY=your-aws-secret-access-key
AWS_REGION=us-east-1
S3_BUCKET=giftfinder-images

# ============================================================================
# OpenAI Configuration (for embeddings and recommendations)
# ============================================================================
OPENAI_API_KEY=sk-your-openai-api-key-here

# ============================================================================
# Instagram Configuration (for web scraping)
# ============================================================================
INSTAGRAM_ACCESS_TOKEN=your-instagram-graph-api-token

# ============================================================================
# Frontend Configuration
# ============================================================================
NEXT_PUBLIC_API_URL=https://api.yourdomain.com

# ============================================================================
# Celery & Flower Monitoring
# ============================================================================
WORKER_CONCURRENCY=4
FLOWER_USER=admin
FLOWER_PASSWORD=your-flower-admin-password-here

# Generate with: openssl rand -hex 16
# FLOWER_PASSWORD=use-secure-password-here

# ============================================================================
# Docker Compose Port Overrides (optional)
# ============================================================================
# API_PORT=8000
# FRONTEND_PORT=3000
# DB_PORT=5432
# REDIS_PORT=6379
# FLOWER_PORT=5555

# ============================================================================
# Deployment-Specific Settings
# ============================================================================
# Uncomment and set for production deployments

# Production database (use managed PostgreSQL service)
# DATABASE_URL=postgresql+asyncpg://user:pass@prod-db.rds.amazonaws.com:5432/giftfinder_prod

# Production Redis (use managed Redis service, e.g., AWS ElastiCache)
# REDIS_URL=redis://prod-redis.cache.amazonaws.com:6379/0

# Email configuration for notifications (if needed)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASSWORD=your-smtp-password

# ============================================================================
# Monitoring & Observability (optional)
# ============================================================================
# Enable these if using external monitoring services

# Sentry error tracking
# SENTRY_DSN=https://your-key@sentry.io/your-project-id

# DataDog APM
# DD_TRACE_ENABLED=true
# DD_API_KEY=your-datadog-api-key
